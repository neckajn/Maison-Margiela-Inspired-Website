html, body {
    max-width: 100%;
    overflow-x: hidden;
}
.background-container {
    position: absolute;
    top: 0;
    left: 0;  
    width: 100%; 
    height: 100%; 
    background-image: url('images/about.png');
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    background-attachment: fixed;
    z-index: -1;
}

.background-container::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(255, 255, 255, 0.7); 
    z-index: -1; 
}

.about-container {
    transform: translateX(-50%, -50%); 
    font-size: 18px; 
    color: rgb(9, 8, 8); 
    font-weight: bold;
    text-align: center; 
    z-index: 1; 
    
    font-family: 'Goudy', sans-serif;
}

.maisonmargiela-container {
    position: fixed;
    top: 11%; 
    left: 40%; 
    transform: translateX(-50%, -50%); 
    font-size: 45px;
    color: rgb(9, 8, 8); 
    font-weight: 550; 
    text-align: center; 
    z-index: 1; 
    font-family: 'Goudy', serif;
}

.maisonmargiela1-container {
    position: fixed;
    top: 29%; 
    left: 30%; 
    font-size: 18px;
    color: rgb(0, 0, 0);
    line-height: 1.6;
    font-weight: 500;
    text-align: justify;
    max-width: 1000px;
    width: 140%; 
    font-family: 'Goudy', sans-serif;
}

.maisonmargiela2-container {
    position: fixed;
    top: 45%; 
    left: 40%; 
    font-size: 18px;
    color: rgb(0, 0, 0);
    line-height: 1.6;
    font-weight: 500;
    text-align: justify;
    max-width: 1000px;
    width: 140%; 
    font-family: 'Goudy', sans-serif;
}

.maisonmargiela3-container {
    position: fixed;
    top: 61%; 
    left: 16%; 
    font-size: 18px;
    color: rgb(0, 0, 0);
    line-height: 1.6;
    font-weight: 500;
    text-align: justify;
    max-width: 1000px;
    width: 140%; 
    font-family: 'Goudy', sans-serif;
}

.BACK {
    font-size: 20px; 
    color: #1d1d1d; 
    text-decoration: none; 
    font-weight: bold; 
    padding: 10px 20px;
    position: absolute;
    bottom: 40px;
    left: 50%; 
    transform: translateX(-50%);
}

@font-face {
    font-family: 'Goudy'; 
    src: url('fonts\goudy-old-style-bold.ttf') format('truetype'); 
}

.BACK {
    font-family: 'Goudy', sans-serif;
    font-size: 22px;
}

body {
    opacity: 1; 
    transition: opacity 0.5s ease;
}

body.fade-out {
    opacity: 0; 
}
